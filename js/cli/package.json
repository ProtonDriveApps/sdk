{
    "name": "proton-drive-cli",
    "private": true,
    "version": "0.0.1",
    "main": "dist/main.js",
    "scripts": {
        "build": "bun build --compile ./src/proton-drive.ts --minify-identifiers",
        "check-types": "tsc --noEmit",
        "generate-types": "bunx openapi-typescript ../../api/openapi-core.json -o ./src/account/api-core-types.ts && bunx openapi-typescript ../../api/openapi-auth.json -o ./src/account/api-auth-types.ts",
        "lint": "eslint src integration-tests --ext .ts --cache --ignore-pattern '**/account/*-types.ts'",
        "pretty": "prettier --write $(find src integration-tests -type f -name '*.ts')",
        "test": "jest",
        "test:watch": "jest --watch --coverage=false"
    },
    "devDependencies": {
        "@swc/core": "^1.12.3",
        "@swc/jest": "^0.2.38",
        "@types/bcryptjs": "^2.4.6",
        "@types/bun": "^1.2.18",
        "@types/jest": "^29.5.14",
        "@types/sharedworker": "^0.0.130",
        "@typescript-eslint/eslint-plugin": "^8.19.1",
        "bun-types": "^1.1.31",
        "eslint": "^8.57.1",
        "eslint-plugin-tsdoc": "^0.3.0",
        "jest": "^29.7.0",
        "openapi-typescript": "^7.4.1",
        "prettier": "^3.6.2",
        "typescript": "^5.5.3",
        "vite": "^5.4.8",
        "vite-plugin-dts": "^4.2.4"
    },
    "dependencies": {
        "@openpgp/noble-hashes": "^1.3.3",
        "@protontech/pmcrypto": "^7.20.0",
        "bcryptjs": "^2.4.3",
        "comlink": "^4.4.2",
        "ky": "^1.7.2",
        "ttag": "^1.8.7"
    },
    "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
